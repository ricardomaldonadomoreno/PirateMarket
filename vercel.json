{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/ficha/:slug",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(facebook|whatsapp|twitter|telegram|linkedin|discord|bot|crawler|spider)"
        }
      ],
      "destination": "/api/og?slug=:slug"
    },
    {
      "source": "/api/og",
      "destination": "/api/og.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
