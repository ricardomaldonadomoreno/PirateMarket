{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/ficha/:slug",
      "destination": "/api/og?slug=:slug"
    },
    {
      "source": "/api/og",
      "destination": "/api/og.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
