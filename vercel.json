{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    {
      "src": "^/api/og$",
      "dest": "/api/og.js"
    },
    {
      "src": "^/ficha/(.*)",
      "dest": "/index.html"
    },
    {
      "src": "^(.*)$",
      "dest": "/index.html"
    }
  ]
}
