{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "routes": [
    {
      "src": "/api/og",
      "dest": "/api/og.js"
    },
    {
      "src": "/ficha/(.*)",
      "dest": "/api/og?slug=$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
